# Database
DB_PASSWORD=secret123

# JWT Auth
JWT_SECRET=change_this_to_a_random_32_char_hex_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# SQLAlchemy
DATABASE_URL=postgresql+asyncpg://tracker_admin:secret123@localhost:5432/medicine_tracker

# Telegram Bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Webhook URL for Telegram (your public Railway URL + /api/webhook)
# Example: https://your-app.railway.app/api/webhook
WEBHOOK_URL=

# Google Gemini (get from aistudio.google.com)
GEMINI_API_KEY=

# Drug composition web search (Layer 3)
# Uses DuckDuckGo Search — NO API KEY NEEDED, completely free
# Just ensure duckduckgo-search is installed (included in requirements.txt)
